# 环境变量配置模板
# 复制此文件为 .env 并填入真实值：
#   cp .env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到仓库。

# ============================================================================
# AI 审查配置
# ============================================================================

# OpenAI 兼容 API 密钥（用于 AI 代码审查和测试生成）
# 留空则使用本地启发式模式（内置规则扫描）
AI_API_KEY=

# API 端点 URL（默认 OpenAI）
# 支持任何兼容 OpenAI Chat Completions 的 API
AI_API_BASE_URL=https://api.openai.com/v1/chat/completions

# 模型名称（推荐 gpt-4o-mini，性价比最高）
AI_MODEL=gpt-4o-mini

# ============================================================================
# CI/CD 配置
# ============================================================================

# Node.js 版本（CI 中默认 20）
NODE_VERSION=20

# 测试超时时间（毫秒）
MOCHA_TIMEOUT=10000

# ============================================================================
# 部署配置
# ============================================================================

# GitHub Pages 部署地址
DEPLOY_URL=https://scoll-Angus.github.io/2408/
